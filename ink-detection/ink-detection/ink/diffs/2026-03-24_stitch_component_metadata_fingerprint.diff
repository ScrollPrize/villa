+def _path_tree_metadata_signature(path: Path) -> tuple[str, int, int, int, str]:
+    """Summarize a path tree by metadata only, without hashing file contents."""
+    root = Path(path)
+    if root.is_file():
+        stat = root.stat()
+        return (
+            root.name,
+            int(stat.st_size),
+            1,
+            int(getattr(stat, "st_mtime_ns", int(stat.st_mtime * 1_000_000_000))),
+            hashlib.sha1(f"{root.name}\0{int(stat.st_size)}\0{int(getattr(stat, 'st_mtime_ns', int(stat.st_mtime * 1_000_000_000)))}".encode("utf-8")).hexdigest(),
+        )
+    if not root.exists():
+        return (root.name, -1, 0, -1, "missing")
+
+    digest = hashlib.sha1()
+    total_size = 0
+    file_count = 0
+    latest_mtime_ns = -1
+    for child in sorted(root.rglob("*"), key=lambda candidate: candidate.as_posix()):
+        if not child.is_file():
+            continue
+        relative_name = child.relative_to(root).as_posix()
+        stat = child.stat()
+        mtime_ns = int(getattr(stat, "st_mtime_ns", int(stat.st_mtime * 1_000_000_000)))
+        digest.update(relative_name.encode("utf-8"))
+        digest.update(b"\0")
+        digest.update(str(int(stat.st_size)).encode("utf-8"))
+        digest.update(b"\0")
+        digest.update(str(mtime_ns).encode("utf-8"))
+        digest.update(b"\0")
+        total_size += int(stat.st_size)
+        file_count += 1
+        latest_mtime_ns = max(latest_mtime_ns, mtime_ns)
+    return (
+        root.name,
+        int(total_size),
+        int(file_count),
+        int(latest_mtime_ns),
+        digest.hexdigest(),
+    )
+
