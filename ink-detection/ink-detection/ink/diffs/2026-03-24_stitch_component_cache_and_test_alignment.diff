+            arrays[f"mask_{idx:05d}"] = np.asarray(region.mask, dtype=np.uint8)
+        tmp_path = path.parent / f".{path.name}.tmp-{uuid.uuid4().hex}"
+        try:
+            with tmp_path.open("wb") as handle:
+                np.savez_compressed(handle, **arrays)
+            os.replace(tmp_path, path)
+        finally:
