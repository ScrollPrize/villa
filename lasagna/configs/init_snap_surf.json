{
	"args": {
		"model-init": "seed",
		"init-mode": "shell-dir-crop",
		"mesh-step": 50.0
	},
	"base": {
		"normal": 1.0,
		"step": 10.0,
		"smooth": 10.0,
		"station_n": 0.1,
		"station_t": 0.1,
		"winding_density": 0.01,
		"data": 0.0,
		"data_plain": 0.0,
		"pred_dt": 0.001,
		"corr": 0.0,
		"bend": 100.0,
		"ext_offset": 0.0,
		"snap_surf": 0.0,
		"snap_surf_map": 0.001
	},
	"stages": [
		{
			"name": "stage1",
			"steps": 300,
			"lr": 0.1,
			"params": ["mesh_ms"],
			"min_scaledown": 0,
			"w_fac": {
				"pred_dt": 0.0,
				"station_n": 10.0,
				"station_t": 10.0,
				"snap_surf": 0.0
			}
		},
		{
			"name": "stage2",
			"steps": 200,
			"lr": 0.01,
			"params": ["mesh_ms"],
			"min_scaledown": 0,
			"w_fac": {
				"pred_dt": 0.0,
				"station_n": 10.0,
				"station_t": 10.0,
				"snap_surf": 0.0
			}
		},
		{
			"name": "affine_seed_quad_init",
			"steps": 100,
			"lr": 0.1,
			"params": ["map_affine"],
			"w_fac": 1.0,
			"args": {
				"status_interval": 10,
				"subdiv": 2,
				"map_global": {
					"distance_scale": 1.0,
					"huber_delta": 5.0,
					"map_station_t": 1.0,
					"map_init": {
						"subdiv": 2,
						"scale_levels": 4,
						"w_dist": 0.0001,
						"w_vec_normal": 1.0,
						"w_surface_normal": 1.0,
						"w_smooth": 0.05,
						"w_bend": 0.01,
						"w_jac": 1.0,
						"w_metric_smooth": 0.05,
						"w_area_smooth": 0.02,
						"w_dense_prior": 0.001,
						"max_sample_distance": 1000.0,
						"max_sample_angle_deg": 180.0,
						"max_step_neighbor_ratio": 0.0
					}
				},
				"affine_seed_quad_init": {
					"enabled": true,
					"quads": 1
				}
			}
		},
		{
			"name": "map_affine_refine",
			"steps": 500,
			"lr": 0.01,
			"params": ["map_affine"],
			"w_fac": 1.0,
			"args": {
				"status_interval": 100,
				"subdiv": 2
			}
		},
		{
			"name": "map_uv_coarse",
			"steps": 500,
			"lr": 0.1,
			"params": ["map_uv_ms"],
			"min_scaledown": 5,
			"w_fac": 1.0,
			"args": {
				"subdiv": 2,
				"status_interval": 20
			}
		},
		{
			"name": "map_uv_refine",
			"steps": 200,
			"lr": 0.1,
			"params": ["map_uv_ms"],
			"min_scaledown": 0,
			"w_fac": 1.0,
			"args": {
				"subdiv": 2,
				"status_interval": 20
			}
		},
		{
			"name": "map_uv_fine",
			"steps": 200,
			"lr": 0.01,
			"params": ["map_uv_ms"],
			"min_scaledown": 0,
			"w_fac": 1.0,
			"args": {
				"subdiv": 2,
				"status_interval": 20
			}
		},
		{
			"name": "snap",
			"steps": 500,
			"lr": 0.1,
			"params": ["mesh_ms"],
			"min_scaledown": 0,
			"default_mul": 0.0,
			"w_fac": {
				"pred_dt": 0.0,
				"snap_surf": 0.0,
				"snap_surf_map": 1.0
			},
			"args": {
				"status_interval": 50,
				"snap_surf": {
					"init_distance": 10.0,
					"w_to_ext": 1.0,
					"debug_obj_dir": true,
					"map_inlier_distance": 4.0,
					"map_opt": {
						"name": "snap_map_opt_final",
						"steps": 1,
						"lr": 0.1,
						"params": ["map_uv_ms"],
						"min_scaledown": 0,
						"w_fac": 1.0,
						"args": {
							"subdiv": 2,
							"debug_obj_dir": "snap_surf_objs"
						}
					}
				}
			}
		}
	]
}
