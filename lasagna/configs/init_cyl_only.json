{
	"args": {
		"model-init": "seed",
		"init-mode": "cylinder_seed",
		"mesh-step": 50.0
	},
	"base": {
		"cyl_normal": 10.0,
		"cyl_smooth": 1.0,
		"cyl_z_smooth": 0.1,
		"cyl_step": 10.0,
		"cyl_radial_mean": 0.1,
		"cyl_bend": 100.0,
		"cyl_conn_mesh": 0.0,
		"cyl_conn_gt": 0.0,
		"cyl_base_mesh": 0.0,
		"cyl_base_gt": 0.0,
		"normal": 1.0,
		"step": 10.0,
		"smooth": 0.0001,
		"station_n": 0.0001,
		"station_t": 0.0001,
		"winding_density": 0.01,
		"data": 0.0,
		"data_plain": 0.0,
		"pred_dt": 0.001,
		"corr": 0.1,
		"bend": 100.0,
		"ext_offset": 0.0
	},
	"stages": [
		{
			"name": "cyl_init",
			"steps": 500,
			"lr": 10.0,
			"params": ["cyl_params"],
			"args": {
				"compile_cyl_normal": true,
				"profile_opt": false
			}
		},
		{
			"name": "cyl_grow",
			"steps": 100,
			"lr": 10.0,
			"params": ["cyl_params"],
			"args": {
				"compile_cyl_normal": true,
				"profile_opt": false
			}
		},
		{
			"name": "cyl_refine",
			"steps": 100,
			"lr": [1.0, 0.1, 0.01, 0.001, 0.0001],
			"params": ["cyl_params"],
			"args": {
				"compile_cyl_normal": true,
				"profile_opt": false
			}
		}
	]
}
