{
  "args": {
    "model-init": "atlas",
    "mesh-step": 50
  },
  "base": {
    "normal": 1.0,
    "step": 10.0,
    "smooth": 10.0,
    "atlas_line_control": 0.0001,
    "atlas_line_other": 0.0001
  },
  "stages": [
    {
      "name": "atlas_init_relax",
      "opt": {
        "steps": "auto",
        "lr": 1.0,
        "params": ["mesh_ms"],
        "args": {
          "atlas_debug_objs": false,
          "atlas_debug_obj_interval": 1
        },
        "w_fac": {
          "atlas_line_control": 0.1,
          "atlas_line_other": 0.1
        }
      }
    },
    {
      "name": "atlas_line_fit",
      "opt": {
        "steps": "auto",
        "lr": 1.0,
        "params": ["mesh_ms"],
        "w_fac": {
          "atlas_line_other": 0.0
        }
      }
    },
    {
      "name": "atlas_line_fit",
      "opt": {
        "steps": "auto",
        "lr": 1.0,
        "params": ["mesh_ms"],
        "w_fac": {
          "smooth": 0.1,
          "atlas_line_other": 0.0
        }
      }
    },
    {
      "name": "atlas_line_fit",
      "opt": {
        "steps": "auto",
        "lr": 0.1,
        "params": ["mesh_ms"],
        "w_fac": {
          "smooth": 0.1,
          "atlas_line_other": 0.0
        }
      }
    }
  ]
}
