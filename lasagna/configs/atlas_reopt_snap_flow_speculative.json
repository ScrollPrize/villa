{
  "args": {
    "model-init": "model",
    "mesh-step": 50,
    "tifxyz-flow-gate-channels": true
  },
  "base": {
    "normal": 1.0,
    "smooth_step": 10.0,
    "avg_step": 0.1,
    "step": 1.0,
    "smooth": 10.0,
    "bend": 100.0,
    "atlas_line_snap": 0.0001,
