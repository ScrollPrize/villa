    "PHerc1667": {
      "display": "Scroll 4",
      "repository": "Biblioteca Nazionale di Napoli ‘Vittorio Emanuele III’ (Officina dei Papiri Ercolanesi)",
      "licenseScope": {
        "EduceLab Data License": "the 3.24 µm and 7.91 µm DLS scans",
        "CC BY-NC 4.0": "all other data"
