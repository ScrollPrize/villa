#include "vc/core/Version.hpp"



auto ProjectInfo::Name() -> std::string
{
    static std::string name{"volume-cartographer"};
    return name;
}

// Version is a git revision string (<sha7>-<commit_date>) computed in the
// top-level CMakeLists.txt as VC_VERSION_STRING; project() carries no numeric
// VERSION so the M.m.p accessors are not meaningful and return 0.
auto ProjectInfo::VersionMajor() -> std::uint32_t { return 0; }
auto ProjectInfo::VersionMinor() -> std::uint32_t { return 0; }
auto ProjectInfo::VersionPatch() -> std::uint32_t { return 0; }

auto ProjectInfo::VersionString() -> std::string
{
    static std::string version("@VC_VERSION_STRING@");
    return version;
}

auto ProjectInfo::NameAndVersion() -> std::string
{
    static std::string nameAndVersion{"volume-cartographer @VC_VERSION_STRING@"};
    return nameAndVersion;
}

auto ProjectInfo::RepositoryURL() -> std::string
{
    static std::string repo("https://github.com/ScrollPrize/villa/tree/main/volume-cartographer");
    return repo;
}

auto ProjectInfo::RepositoryHash() -> std::string
{
    static std::string hash("@GIT_SHA1@");
    return hash;
}

auto ProjectInfo::RepositoryShortHash() -> std::string
{
    static std::string hashShort("@GIT_SHA1_SHORT@");
    return hashShort;
}