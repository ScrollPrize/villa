{
  "contractVersion": 1,
  "domain": "volume",
  "methods": {
    "volume.open": {
      "params": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "volumeId": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "path"
        ]
      },
      "errors": [
        -32602,
        -32005,
        -32007,
        -32010
      ],
      "successProbe": false,
      "errorProbes": [
        {
          "name": "empty path",
          "state": "loaded",
          "params": {
            "path": ""
          },
          "code": -32005
        },
        {
          "name": "missing package",
          "state": "loaded",
          "params": {
            "path": "/vc3d-contract/does-not-exist.volpkg.json"
          },
          "code": -32005
        }
      ],
      "unprobedErrors": [
        -32007,
        -32010
      ],
      "mcp": {
        "tool": "vc3d_open_volume",
        "paramRenames": {
          "volumeId": "volume_id"
        }
      }
    },
    "volume.select": {
      "params": {
        "type": "object",
        "properties": {
          "volumeId": {
            "type": "string"
          }
        },
        "required": [
          "volumeId"
        ]
      },
      "errors": [
        -32602,
        -32000,
        -32007,
        -32005
      ],
      "successProbe": {
        "params": {
          "volumeId": "vol1"
        }
      },
      "errorProbes": [
        {
          "name": "unknown volume",
          "state": "loaded",
          "params": {
            "volumeId": "__missing__"
          },
          "code": -32007
        },
        {
          "name": "no volume package",
          "state": "no-project",
          "params": {
            "volumeId": "vol1"
          },
          "code": -32000
        }
      ],
      "unprobedErrors": [
        -32005
      ],
      "mcp": {
        "tool": "vc3d_select_volume",
        "paramRenames": {
          "volumeId": "volume_id"
        }
      }
    },
    "volume.list": {
      "params": {
        "type": "object",
        "properties": {}
      },
      "errors": [
        -32000
      ],
      "errorProbes": [
        {
          "name": "no volume package",
          "state": "no-project",
          "params": {},
          "code": -32000
        }
      ],
      "mcp": {
        "tool": "vc3d_list_volumes"
      }
    }
  }
}
